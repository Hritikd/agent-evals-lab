{
  "name": "agent-evals-lab",
  "version": "1.0.0",
  "description": "A TypeScript workbench for evaluating AI agent reliability, risk, latency, and tool-use behavior.",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx scripts/run-eval.ts"
  },
  "keywords": [
    "ai",
    "agents",
    "evals",
    "observability",
    "typescript",
    "llmops"
  ],
  "author": "Hritik Datta",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.468.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  }
}
